---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="MWC 2026 Agent 新闻聚合 - 世界移动通信大会最新动态" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body class="bg-gray-50 min-h-screen">
  <header class="bg-gradient-to-r from-blue-600 to-purple-600 text-white shadow-lg">
    <div class="container mx-auto px-4 py-6">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold">🤖 MWC 2026 Agent News</h1>
          <p class="text-blue-100 mt-1">世界移动通信大会 · Agent 智能新闻聚合</p>
        </div>
        <nav class="hidden md:flex space-x-4">
          <a href="/" class="hover:text-blue-200 transition">首页</a>
          <a href="#news" class="hover:text-blue-200 transition">新闻</a>
          <a href="#about" class="hover:text-blue-200 transition">关于</a>
        </nav>
      </div>
    </div>
  </header>
  
  <main>
    <slot />
  </main>
  
  <footer class="bg-dark text-white py-8 mt-12">
    <div class="container mx-auto px-4 text-center">
      <p class="text-gray-400">© 2026 MWC Agent News. 自动聚合 · 智能呈现</p>
      <p class="text-gray-500 text-sm mt-2">数据来源: GSMA MWC Barcelona 2026</p>
    </div>
  </footer>
</body>
</html>
